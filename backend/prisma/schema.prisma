generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  passwordHash      String
  phone             String?
  tier              Tier             @default(FREE)
  lastDailyDigestAt DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  searches          Search[]
  credentials       SiteCredential[]

  @@map("users")
}

model SiteCredential {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain            String
  username          String
  encryptedPassword String
  sessionCookies    String?
  lastLogin         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  searches          Search[]

  @@unique([userId, domain])
  @@map("site_credentials")
}

model Search {
  id               String           @id @default(cuid())
  userId           String?
  user             User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId     String?
  credential       SiteCredential?  @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  keyword          String
  websiteUrl       String
  checkInterval    Int              @default(30)
  notificationType NotificationType @default(EMAIL)
  notifyEmail      String?
  isActive         Boolean          @default(true)
  inStockOnly      Boolean          @default(false)
  maxPrice         Float?
  lastChecked      DateTime?
  lastMatchHash    String?
  expiresAt        DateTime?
  searchAllGroupId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  matches          Match[]
  notifications    Notification[]

  @@map("searches")
}

model Match {
  id            String              @id @default(cuid())
  searchId      String
  search        Search              @relation(fields: [searchId], references: [id], onDelete: Cascade)
  title         String
  price         Float?
  regularPrice  Float?              // Original price before discount (for strikethrough display)
  url           String
  hash          String
  thumbnail     String?
  postDate      DateTime?
  seller        String?
  foundAt       DateTime            @default(now())
  notifications NotificationMatch[]

  @@unique([searchId, url])
  @@map("matches")
}

model Notification {
  id       String              @id @default(cuid())
  searchId String
  search   Search              @relation(fields: [searchId], references: [id], onDelete: Cascade)
  type     NotificationType
  sentAt   DateTime            @default(now())
  status   String              @default("sent")
  matches  NotificationMatch[]

  @@map("notifications")
}

model NotificationMatch {
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  matchId        String
  match          Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@id([notificationId, matchId])
  @@map("notification_matches")
}

enum Tier {
  FREE
  PRO
}

model SiteMap {
  id            String   @id @default(cuid())
  domain        String   @unique
  siteType      String
  listingUrls   String   @default("[]")
  searchUrl     String?
  discoveredAt  DateTime @default(now())
  expiresAt     DateTime
  hitCount      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("site_maps")
}

enum NotificationType {
  EMAIL
  SMS
  BOTH
}

model MonitoredSite {
  id               String            @id @default(cuid())
  domain           String            @unique
  name             String
  url              String
  siteType         String            @default("generic")
  adapterType      String            @default("generic")
  isEnabled        Boolean           @default(true)
  isPaused         Boolean           @default(false)
  requiresSucuri   Boolean           @default(false)
  requiresAuth     Boolean           @default(false)
  searchUrlPattern String?
  notes            String?

  // Site classification (determines crawl strategy + base rates)
  siteCategory       String          @default("retailer") // retailer, forum, classified, auction

  // Crawl scheduling state
  lastCrawlAt        DateTime?
  nextCrawlAt        DateTime?
  crawlIntervalMin   Int             @default(120)
  crawlLock          String?
  crawlLockExpiresAt DateTime?

  // Pressure/capacity model (replaces old multiplier stack)
  pressure           Float           @default(0)    // 0-1, rolling average from last 20 crawls
  capacity           Float           @default(1)    // e^(-3 × pressure), 0.05-1.0
  baseBudget         Int             @default(60)   // Tokens per hour (admin-configurable)

  // Difficulty signals (auto-measured from crawl responses)
  avgResponseTimeMs   Int?
  consecutiveFailures Int            @default(0)
  hasWaf              Boolean        @default(false)
  hasRateLimit        Boolean        @default(false)
  hasCaptcha          Boolean        @default(false)

  // Per-site crawl tuning (JSON overrides, null fields → use global defaults)
  crawlTuning        Json?

  // Watermark tracking (Tier 1 — new items crawl)
  lastWatermarkUrl   String?

  // Tier state (JSONB tracking cycle progress for Tiers 2-4)
  tierState          Json            @default("{}")

  // Cold start tracking
  addedAt            DateTime        @default(now())
  coldStartOverride  Boolean         @default(false)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  healthChecks    SiteHealthCheck[]
  crawlEvents     CrawlEvent[]
  products        ProductIndex[]
  dismissedIssues DismissedIssue[]

  @@map("monitored_sites")
}

model ProductIndex {
  id          String        @id @default(cuid())
  siteId      String
  site        MonitoredSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url         String
  title        String
  price        Float?
  regularPrice Float?              // Original price before discount (for strikethrough display)
  stockStatus  String?       // "in_stock" | "out_of_stock" | "unknown"
  thumbnail   String?
  category    String?       // "new" | "used" | "auction_lot" | "classified"
  tags        String?       // Comma-separated product tags from source (e.g. Shopify)
  productType String?       // "firearm" | "ammunition" | "optics" | "parts" | "gear" | "knives" | "other"
  closingAt   DateTime?     // For auction lots — enables live countdown timer
  firstSeenAt DateTime      @default(now())
  lastSeenAt  DateTime      @default(now())
  isActive    Boolean       @default(true)

  @@unique([siteId, url])
  @@index([siteId, lastSeenAt])
  @@index([title])
  @@map("product_index")
}

model KeywordGroup {
  id            String         @id @default(cuid())
  canonicalName String         @unique
  aliases       KeywordAlias[]
  createdAt     DateTime       @default(now())

  @@map("keyword_groups")
}

model KeywordAlias {
  id      String       @id @default(cuid())
  groupId String
  group   KeywordGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  alias   String       @unique

  @@index([alias])
  @@map("keyword_aliases")
}

model CrawlEvent {
  id             String        @id @default(cuid())
  siteId         String
  site           MonitoredSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status         String        // success, fail, timeout, blocked, captcha
  responseTimeMs Int?
  statusCode     Int?
  matchesFound   Int           @default(0)
  errorMessage   String?
  crawledAt      DateTime      @default(now())

  @@index([siteId, crawledAt])
  @@map("crawl_events")
}

model SiteHealthCheck {
  id             String        @id @default(cuid())
  siteId         String
  site           MonitoredSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  isReachable    Boolean
  canScrape      Boolean
  responseTimeMs Int?
  errorMessage   String?
  checkedAt      DateTime      @default(now())

  @@index([siteId, checkedAt])
  @@map("site_health_checks")
}

model DismissedIssue {
  id                String        @id @default(cuid())
  siteId            String
  site              MonitoredSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  issueType         String        // e.g. "waf_blocked", "no_products", "consecutive_failures"
  dismissedAt       DateTime      @default(now())
  conditionSnapshot String?       // snapshot when dismissed; if condition changes, issue re-surfaces

  @@unique([siteId, issueType])
  @@index([siteId])
  @@map("dismissed_issues")
}
